APP_NAME="Document Q&A RAG API"
ENVIRONMENT="local"

# Supabase Postgres direct or pooler connection string.
# Example:
# DATABASE_URL="postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
DATABASE_URL=""
DB_POOL_SIZE=1
DB_MAX_OVERFLOW=1

# Supabase Auth.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_JWT_AUDIENCE="authenticated"
# Prefer setting this for HS256 projects. If omitted, the API verifies against Supabase JWKS.
SUPABASE_JWT_SECRET=""

# Comma-separated frontend origins.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# AI providers.
HUGGINGFACE_API_TOKEN=""
HUGGINGFACE_EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
HUGGINGFACE_TIMEOUT_SECONDS=45
HUGGINGFACE_BATCH_SIZE=8

GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_TIMEOUT_SECONDS=45

# Upload and retrieval limits.
MAX_UPLOAD_MB=50
RAG_CANDIDATE_LIMIT=20
RAG_CONTEXT_LIMIT=5
